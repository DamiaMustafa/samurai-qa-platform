# Samurai Central Staging - Environment Variables
# Copy this file to .env and fill in your values

# Base URL for Samurai Central Staging
BASE_URL=https://staging.visionsamur.ai

# API Base URL (if different from BASE_URL)
API_BASE_URL=https://staging.visionsamur.ai/api

# Test Credentials - Admin
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Test Credentials - Standard User
STANDARD_USERNAME=
STANDARD_PASSWORD=

# Dashboard API URL (where the reporter sends results)
DASHBOARD_API_URL=http://localhost:3000/api

# Test Configuration
TEST_TIMEOUT=60000
TEST_RETRIES=0
TEST_WORKERS=1
