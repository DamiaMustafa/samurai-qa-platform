{
  "name": "@samurai-qa/tests",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "test": "npx playwright test",
    "test:select": "node scripts/select-env.js",
    "test:staging": "ACTIVE_ENV=staging npx playwright test",
    "test:dev": "ACTIVE_ENV=dev npx playwright test",
    "test:prod": "ACTIVE_ENV=prod npx playwright test",
    "test:smoke": "npx playwright test --grep @smoke",
    "test:headed": "npx playwright test --headed",
    "test:ui": "npx playwright test --ui",
    "test:debug": "npx playwright test --debug",
    "report": "npx playwright show-report",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@samurai-qa/shared": "*",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "allure-commandline": "^2.33.0",
    "allure-playwright": "^3.2.0",
    "dotenv": "^16.4.0",
    "typescript": "^5.5.0"
  }
}
