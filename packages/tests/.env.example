# ──────────────────────────────────────────────
# Active environment (staging | dev | prod)
# Set via CLI flag:  --env staging
# Or interactively:  npm run test:select
# ──────────────────────────────────────────────
ACTIVE_ENV=staging

# ──────────────────────────────────────────────
# Staging
# ──────────────────────────────────────────────
STAGING_BASE_URL=
STAGING_EMAIL=
STAGING_PASSWORD=

# ──────────────────────────────────────────────
# Dev
# ──────────────────────────────────────────────
DEV_BASE_URL=
DEV_EMAIL=
DEV_PASSWORD=

# ──────────────────────────────────────────────
# Prod
# ──────────────────────────────────────────────
PROD_BASE_URL=
PROD_EMAIL=
PROD_PASSWORD=

# ──────────────────────────────────────────────
# Dashboard Reporter (shared across envs)
# ──────────────────────────────────────────────
DASHBOARD_API_URL=http://localhost:3000/api

# ──────────────────────────────────────────────
# Test Config
# ──────────────────────────────────────────────
TEST_TIMEOUT=60000
TEST_RETRIES=0
TEST_WORKERS=1
